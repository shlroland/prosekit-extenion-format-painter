{
  "name": "prosekit-extension-format-painter",
  "type": "module",
  "version": "3.0.0",
  "packageManager": "pnpm@11.5.1",
  "description": "A headless ProseKit extension for format painter interactions",
  "author": "shlroland",
  "license": "MIT",
  "homepage": "https://github.com/shlroland/prosekit-extenion-format-painter#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shlroland/prosekit-extenion-format-painter.git"
  },
  "bugs": "https://github.com/shlroland/prosekit-extenion-format-painter/issues",
  "keywords": [
    "prosekit",
    "prosemirror",
    "format-painter",
    "rich-text-editor"
  ],
  "sideEffects": [
    "./src/style.css"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./style.css": "./src/style.css"
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsdown && vite build website",
    "dev": "vite website",
    "lint": "eslint .",
    "fix": "eslint --fix . && prettier --write .",
    "pretest": "playwright install chromium",
    "test": "vitest",
    "test:package": "pnpm build && node scripts/verify-package.mjs",
    "typecheck": "tsc -b"
  },
  "dependencies": {
    "@prosekit/core": "^0.12.2",
    "@prosekit/pm": "^0.1.17"
  },
  "devDependencies": {
    "@ocavue/eslint-config": "^4.5.9",
    "@ocavue/tsconfig": "^0.7.1",
    "@prosekit/basic": "^0.9.4",
    "@prosekit/extensions": "^0.17.3",
    "@types/node": "^22.19.11",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.2",
    "@vitest/browser-playwright": "^4.1.8",
    "diffable-html-snapshot": "^0.2.0",
    "eslint": "^10.4.1",
    "lucide-react": "^0.561.0",
    "playwright": "^1.60.0",
    "prettier": "^3.8.3",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "tsdown": "^0.22.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  }
}
